# Dashboard Server Environment Variables
# Copy this to .env and fill in your values

# Discord OAuth2 (from https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# MongoDB (same connection string as your bot)
DATABASE_TOKEN=

# Server
PORT=8080
SESSION_SECRET=change-this-to-a-random-secret-string

# --- Development (separate frontend/backend) ---
DASHBOARD_URL=http://localhost:3000
CALLBACK_URL=http://localhost:8080/api/auth/discord/callback

# --- Production (Fly.io — set these as fly secrets) ---
# NODE_ENV=production          (set in fly.toml)
# APP_URL=https://your-app.fly.dev
# CALLBACK_URL=/api/auth/discord/callback  (relative is fine in production)
