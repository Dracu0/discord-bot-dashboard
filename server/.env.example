# Dashboard Server Environment Variables
# Copy this to .env and fill in your values

# Discord OAuth2 (from https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# MongoDB (same connection string as your bot)
DATABASE_TOKEN=

# Server
PORT=8080
# Must be at least 32 characters (server exits on weak secret)
SESSION_SECRET=change-this-to-a-random-secret-string-with-32-chars-min

# --- Bot Status Connection ---
# Option A: Redis pub/sub (real-time, required for production multi-instance)
REDIS_URL=
# Option B: Direct health poll (works without Redis, good for local dev)
# Point this at the bot's health endpoint (see BOT_HEALTH_PORT in bot .env)
BOT_HEALTH_URL=http://localhost:8080/health
# If the bot's health endpoint requires a bearer token
BOT_HEALTH_TOKEN=

# --- Development (separate frontend/backend) ---
DASHBOARD_URL=http://localhost:3000
CALLBACK_URL=http://localhost:8080/auth/discord/callback
# Optional comma-separated extra origins allowed to open WebSocket connections
# Example: WS_ALLOWED_ORIGINS=https://admin.example.com,https://staging-admin.example.com
WS_ALLOWED_ORIGINS=

# --- Production (Fly.io — set these as fly secrets) ---
# NODE_ENV=production          (set in fly.toml)
# APP_URL=https://your-app.fly.dev
# CALLBACK_URL=/auth/discord/callback  (relative is fine in production)
# Recommended: set REDIS_URL in production for cross-instance real-time events
# Optional: expected number of running app instances (default 1).
# If >1 in production and REDIS_URL is missing, the server exits at startup.
EXPECTED_INSTANCES=1
