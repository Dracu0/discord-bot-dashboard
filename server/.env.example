# Dashboard Server Environment Variables
# Copy this to .env and fill in your values

# Discord OAuth2 (from https://discord.com/developers/applications)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=

# MongoDB (same connection string as your bot)
DATABASE_TOKEN=

# Server
PORT=8080
SESSION_SECRET=change-this-to-a-random-secret-string

# Dashboard URL (frontend)
DASHBOARD_URL=http://localhost:3000

# Callback URL (must match Discord OAuth2 redirect)
CALLBACK_URL=http://localhost:8080/auth/discord/callback
